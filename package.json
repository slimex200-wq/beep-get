{
  "name": "beep-get",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "supabase:dry-run": "supabase db push --dry-run",
    "supabase:lint": "supabase db lint",
    "apple:oauth-secret": "node scripts/apple-client-secret.mjs",
    "eas:info": "npx eas-cli@latest project:info",
    "build:android:preview": "npx eas-cli@latest build -p android --profile preview",
    "build:android:production": "npx eas-cli@latest build -p android --profile production",
    "submit:android:production": "npx eas-cli@latest submit -p android --profile production"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@supabase/supabase-js": "^2.101.1",
    "@types/react": "~19.1.10",
    "expo": "~54.0.34",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-iap": "^4.2.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "typescript": "~5.9.2",
    "zustand": "^5.0.12"
  },
  "private": true,
  "overrides": {
    "@bacons/xcode": "1.0.0-alpha.33",
    "@expo/plist": "0.5.3",
    "@xmldom/xmldom": "0.9.10"
  },
  "devDependencies": {
    "@bacons/apple-targets": "^4.0.6",
    "@testing-library/react-native": "^13.3.0",
    "@types/jest": "^29.5.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "supabase": "^2.98.0",
    "ts-jest": "^29.4.9"
  }
}
