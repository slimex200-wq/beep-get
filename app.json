{
  "expo": {
    "name": "Beep Get",
    "slug": "beep-get",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/beepy-app-icon-20260514.png",
    "scheme": "beepget",
    "splash": {
      "image": "./assets/beepy-splash-icon-20260514.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5EE"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/beepy-splash-icon-20260514.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#FFF5EE"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#D9342B"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BEEP-GET uses the camera to record 2 second Blink messages.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "BEEP-GET can use contacts to help find friends."
        }
      ],
      "./modules/beep-widget/plugin/build/index",
      "@bacons/apple-targets"
    ],
    "ios": {
      "bundleIdentifier": "com.hypeboyo.beepget",
      "appleTeamId": "YR267UY7UX",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.beepget.shared"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.hypeboyo.beepget",
      "adaptiveIcon": {
        "foregroundImage": "./assets/beepy-adaptive-icon-20260514.png",
        "backgroundColor": "#FFF5EE"
      },
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "favicon": "./assets/beepy-app-icon-20260514.png"
    },
    "extra": {
      "eas": {
        "projectId": "2c41736e-942b-4593-8fcd-53373d03ee53"
      }
    },
    "owner": "hypeboyo"
  }
}
